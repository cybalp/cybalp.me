# ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
# ❯ @status OK!
# ❯ @path ./.npmrc
# ❯ @desc pnpm configuration — package manager enforcement and hoisting rules
# ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

# ❯ PACKAGE MANAGER
# ❯ @docs Enforces the exact pnpm version declared in package.json#packageManager field
manage-package-manager-versions = true

# ❯ HOISTING
# ❯ @docs Hoists all iconify icon packages to node_modules root so astro-icon can resolve them at build time
# ❯ @gogogo new icon set
public-hoist-pattern[]=*iconify*