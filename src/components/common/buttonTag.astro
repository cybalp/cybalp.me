---
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
// ❯ @status OK!
// ❯ @path ./src/components/common/buttonTag.astro
// ❯ @desc Button tag component with optional dot indicator.
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

// ❯ PROPS
interface Props {
	size?: string;
	dot?: boolean;
	href?: string;
	label?: string;
}

// ❯ PROPS DESTRUCTURING
const { dot, href, label }: Props = Astro.props;
---

<!-- ❯ RENDER -->
<a href={href} aria-label={label} class="btn-regular h-8 text-sm px-3 rounded-lg">
    {dot && <div class="h-1 w-1 bg-(--btn-content) dark:bg-(--card-bg) transition rounded-md mr-2"></div>}
    <slot></slot>
</a>