---
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
// ❯ @status OK!
// ❯ @path ./src/components/common/imageWrapper.astro
// ❯ @desc Image wrapper component with optimization.
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

import { Image } from "astro:assets";
import path from "node:path";
import { url } from "@utils/url";
// ❯ IMPORTS
import type { ImageMetadata } from "astro";

// ❯ PROPS
interface Props {
	id?: string;
	src: string;
	class?: string;
	alt?: string;
	position?: string;
	basePath?: string;
	style?: string;
	loading?: "lazy" | "eager";
	decoding?: "async" | "auto" | "sync";
	fetchpriority?: "high" | "low" | "auto";
}

// ❯ PROPS DESTRUCTURING
const {
	id,
	src,
	alt,
	position = "center",
	basePath = "/",
	style,
	loading = "lazy",
	decoding = "async",
} = Astro.props;

// ❯ @doc Auto-elevate fetchpriority for eager images to hint the browser to fetch ASAP.
const fetchpriority = Astro.props.fetchpriority ?? (loading === "eager" ? "high" : "auto");
const className = Astro.props.class;

// ❯ IMAGE DETECTION
const isLocal = !(
	src.startsWith("/") ||
	src.startsWith("http") ||
	src.startsWith("https") ||
	src.startsWith("data:")
);
const isPublic = src.startsWith("/");

// ❯ IMAGE LOADING
// ❯ @doc Temporary workaround for dynamic image import.
// ❯ @hint https://github.com/withastro/astro/issues/3373
let img: ImageMetadata | undefined;
if (isLocal) {
	const files = import.meta.glob<ImageMetadata>("../../**", {
		import: "default",
	});
	let normalizedPath = path
		.normalize(path.join("../../", basePath, src))
		.replace(/\\/g, "/");
	const file = files[normalizedPath];
	if (!file) {
		console.error(
			`\n[ERROR] Image file not found: ${normalizedPath.replace("../../", "src/")}`,
		);
	} else {
		img = await file();
	}
}

// ❯ COMPUTED
const imageClass = "w-full h-full object-cover";
const imageStyle = `object-position: ${position}`;
---

<!-- ❯ RENDER -->
<div id={id} class:list={[className, 'overflow-hidden relative']} style={style}>
    <div class="transition absolute inset-0 bg-black/3 dark:bg-black/9 pointer-events-none"></div>
    {isLocal && img && <Image src={img} alt={alt || ""} class={imageClass} style={imageStyle} loading={loading} decoding={decoding} fetchpriority={fetchpriority}/>}
    {!isLocal && <img src={isPublic ? url(src) : src} alt={alt || ""} class={imageClass} style={imageStyle} loading={loading} decoding={decoding} fetchpriority={fetchpriority}/>}
</div>