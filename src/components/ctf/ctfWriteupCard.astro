---
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
// ❯ @status OK!
// ❯ @path ./src/components/ctf/ctfWriteupCard.astro
// ❯ @desc CTF writeup card — mirrors PostCard but links to /ctf/writeups/... .
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import ImageWrapper from "@components/common/imageWrapper.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import PostMetadata from "@components/post/postMeta.astro";
import { getCtfWriteupUrl, getFileDirFromPath } from "@utils/url";
// ❯ IMPORTS
import { Icon } from "astro-icon/components";

// ❯ PROPS
interface Props {
	class?: string;
	entry: CollectionEntry<"ctf">;
	style?: string;
}

// ❯ PROPS DESTRUCTURING
const className = Astro.props.class;
const { entry, style } = Astro.props;

// ❯ COMPUTED
const href = getCtfWriteupUrl(entry);
const CTF_DISPLAY_CATEGORY = "CTF!";

const {
	title,
	published,
	updated,
	description,
	cover,
	tags,
	pinned,
} = entry.data;

const hasCover = cover !== undefined && cover !== null && cover !== "";

const coverWidth = "28%";

const { remarkPluginFrontmatter } = await render(entry);

const imageBaseDir = getFileDirFromPath(entry.filePath || "");
---

<!-- ❯ RENDER -->
<div class:list={["post-card card-base flex flex-col-reverse md:flex-col w-full rounded-(--radius-large) overflow-hidden relative", {"post-card-pinned": pinned, "post-card-has-cover": hasCover}, className]} style={style}>
    <div class:list={["post-card-text pl-6 md:pl-9 pr-6 md:pr-2 pt-6 md:pt-7 pb-6 relative", {"w-full md:w-[calc(100%-52px-12px)]": !hasCover, "w-full md:w-[calc(100%-var(--coverWidth)-12px)]": hasCover}]}>
        <a href={href}
           class="no-underline transition group w-full block font-bold mb-3 text-3xl text-90
            hover:text-(--primary) dark:hover:text-(--primary)
            active:text-(--title-active) dark:active:text-(--title-active)
            before:w-1 before:h-5 before:rounded-md before:bg-(--primary)
            before:absolute before:top-[35px] before:left-[18px] before:hidden md:before:block
        ">
            {pinned && <span class="post-pinned-badge inline-flex items-center text-(--primary) text-2xl mr-2 -translate-y-0.5">
                <Icon name="mdi:pin" class="inline"></Icon>
            </span>}
            {title}
            <Icon class="inline text-[2rem] text-(--primary) md:hidden translate-y-0.5 absolute" name="material-symbols:chevron-right-rounded" ></Icon>
            <Icon class="text-(--primary) text-[2rem] transition hidden md:inline absolute translate-y-0.5 opacity-0 group-hover:opacity-100 -translate-x-1 group-hover:translate-x-0" name="material-symbols:chevron-right-rounded"></Icon>
        </a>
        <PostMetadata published={published} updated={updated} tags={tags} category={CTF_DISPLAY_CATEGORY} hideTagsForMobile={true} hideUpdateDate={true} postUrl={href} className="mb-4"></PostMetadata>
        <div class:list={["transition text-75 mb-4 pr-4 leading-relaxed", {"line-clamp-2 md:line-clamp-1": !description}]}>
            { description || remarkPluginFrontmatter.excerpt }
        </div>
        <div class="text-sm text-black/40 dark:text-white/40 flex gap-4 transition items-center">
            <div class="flex items-center gap-1.5">
                <Icon name="material-symbols:article-outline-rounded" class="text-base opacity-60"></Icon>
                <span>
                    {remarkPluginFrontmatter.words} {" " + i18n(remarkPluginFrontmatter.words === 1 ? I18nKey.wordCount : I18nKey.wordsCount)}
                </span>
            </div>
            <div class="opacity-30">|</div>
            <div class="flex items-center gap-1.5">
                <Icon name="material-symbols:schedule-outline-rounded" class="text-base opacity-60"></Icon>
                <span>
                    {remarkPluginFrontmatter.minutes} {" " + i18n(remarkPluginFrontmatter.minutes === 1 ? I18nKey.minuteCount : I18nKey.minutesCount)}
                </span>
            </div>
        </div>
    </div>

    {hasCover &&
        <a href={href} aria-label={title} class:list={["no-underline group post-cover-image",
                "max-h-[35vh] md:max-h-none mx-4 mt-4 mb-0 md:mx-0 md:mt-0",
                "md:w-(--coverWidth) relative md:absolute md:top-3 md:bottom-3 md:right-3 rounded-xl overflow-hidden active:scale-95",
                "post-cover-image-mobile"
            ]}
        >
            <div class="absolute pointer-events-none z-10 w-full h-full group-hover:bg-black/30 group-active:bg-black/50 transition"></div>
            <div class="absolute pointer-events-none z-20 w-full h-full flex items-center justify-center">
                <Icon name="material-symbols:chevron-right-rounded"
                    class="transition opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 text-white text-5xl">
                </Icon>
            </div>
            <ImageWrapper src={cover} basePath={imageBaseDir} alt="Cover Image of the Post"
                    class="w-full h-full" objectFit="contain">
            </ImageWrapper>
        </a>
    }

    {!hasCover &&
        <a href={href} aria-label={title} class="no-underline hidden! md:flex! btn-regular w-13
            absolute right-3 top-3 bottom-3 rounded-xl bg-(--enter-btn-bg)
            hover:bg-(--enter-btn-bg-hover) active:bg-(--enter-btn-bg-active) active:scale-95
        ">
            <Icon name="material-symbols:chevron-right-rounded"
                class="transition text-(--primary) text-4xl mx-auto">
            </Icon>
        </a>
    }
</div>

<!-- ❯ STYLES -->
<style define:vars={{coverWidth}}>
    .post-card a {
        text-decoration: none;
    }

    .post-card {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        will-change: transform, box-shadow;
    }
    
    .post-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12), 0 0 0 1px rgba(0, 0, 0, 0.05);
    }
    
    @media (prefers-color-scheme: dark) {
        .post-card:hover {
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(255, 255, 255, 0.1);
        }
    }
    
    .post-card-pinned {
        position: relative;
    }
    
    .post-card-pinned::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: linear-gradient(90deg, var(--primary), transparent);
        opacity: 0.6;
        z-index: 1;
        border-radius: var(--radius-large) var(--radius-large) 0 0;
    }
    
    .post-pinned-badge {
        filter: drop-shadow(0 0 4px currentColor);
        animation: pulse-glow 2s ease-in-out infinite;
    }
    
    @keyframes pulse-glow {
        0%, 100% {
            filter: drop-shadow(0 0 4px currentColor);
        }
        50% {
            filter: drop-shadow(0 0 8px currentColor);
        }
    }
    
    
    @media (max-width: 768px) {
        .post-card:hover {
            transform: none;
        }
        
        .post-card {
            transition: box-shadow 0.3s ease;
        }
        
        .post-card-pinned::before {
            height: 2px;
        }

        .post-card-has-cover {
            flex-direction: column;
        }
        .post-card-has-cover .post-cover-image-mobile {
            order: -1;
            position: absolute;
            inset: 0;
            max-height: none;
            margin: 0;
            border-radius: var(--radius-large);
        }
        .post-card-has-cover .post-card-text {
            position: relative;
            z-index: 2;
            margin-top: auto;
            background: color-mix(in oklch, var(--card-bg) 92%, transparent);
            -webkit-backdrop-filter: blur(4px);
            backdrop-filter: blur(4px);
        }
    }
</style>
