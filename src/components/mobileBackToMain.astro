---
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
// ❯ @status OK!
// ❯ @path ./src/components/mobileBackToMain.astro
// ❯ @desc Banner-strip pill button (same rules as Support Me). Opens profile popup on click.
//        Mobile-only; shares .banner-strip__btn styling with Support Me for consistency.
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

// ❯ IMPORTS
import { Icon } from "astro-icon/components";
import { profileConfig } from "@/config";

// ❯ PROPS
// ❯ @hint isMainPage kept for potential future use (e.g. different behavior on main).
interface Props {
    isMainPage?: boolean;
}
const { isMainPage = false } = Astro.props;

// ❯ DATA
const avatar = profileConfig.avatar;
---

<!-- ❯ RENDER — same base as Support Me (.banner-strip__btn), only Main opens profile popup -->
<button
    id="mobile-btm-btn"
    type="button"
    aria-label="Open profile card"
    aria-expanded="false"
    class="banner-strip__btn group onload-animation-up transition-all flex justify-center items-center gap-2 rounded-full pl-1.5 pr-3 h-9 bg-black/60 hover:bg-black/70 active:bg-black/85 md:hidden cursor-pointer pointer-events-auto"
>
    {avatar ? (
        <img
            src={avatar}
            alt="Profile"
            width="24"
            height="24"
            class="rounded-full w-6 h-6 object-cover shrink-0 ring-1 ring-white/20"
            loading="eager"
        />
    ) : (
        <Icon
            class="text-white/75 text-[1.1rem] shrink-0"
            name="material-symbols:terminal"
        />
    )}
    <span class="text-white/80 text-xs font-medium leading-none select-none">Main</span>
    <Icon
        class="text-[oklch(0.75_0.14_var(--hue))] text-[0.7rem] shrink-0 -ml-0.5
               transition-transform duration-200 group-hover:translate-x-0.5"
        name="fa6-solid:chevron-right"
    />
</button>

<!-- ❯ BUTTON CONTROLLER -->
<script is:inline>
// ❯ Click handler — opens profile popup
function initBackToMainBtn() {
    const btn = document.getElementById('mobile-btm-btn');
    if (!btn) return;
    // ❯ avoid attaching duplicate listeners on re-init
    if (btn._btmInitialized) return;
    btn._btmInitialized = true;
    btn.addEventListener('click', () => {
        if (typeof window.openProfilePopup === 'function') {
            window.openProfilePopup();
            btn.setAttribute('aria-expanded', 'true');
        }
    });
}

// ❯ Initial setup
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBackToMainBtn);
} else {
    initBackToMainBtn();
}

// ❯ Swup page transitions — reset guard so re-init works
document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('mobile-btm-btn');
    if (btn) {
        btn._btmInitialized = false;
        btn.setAttribute('aria-expanded', 'false');
    }
    initBackToMainBtn();
});

// ❯ @doc Placeholder for any future visibility logic. Main button is now shown on all pages in mobile view.
function updateMobileBackToMainVisibility() {
    const btn = document.getElementById('mobile-btm-btn');
    if (!btn) return;
    // Main button always visible on mobile; no hide-on-main logic.
}
window.updateMobileBackToMainVisibility = updateMobileBackToMainVisibility;
updateMobileBackToMainVisibility();
</script>
