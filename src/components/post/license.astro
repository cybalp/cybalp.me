---
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
// ❯ @status OK!
// ❯ @path ./src/components/post/license.astro
// ❯ @desc License information component for posts.
// ❯       When a cover image is provided, it is used as a dark semi-transparent
// ❯       background behind the card content (like a social share card).
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

// ❯ IMPORTS
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import { formatDateToYYYYMMDD } from "@utils/date";
import { getPostUrlBySlug } from "@utils/url";
import { Icon } from "astro-icon/components";
import { postConfig, profileConfig, siteConfig } from "@/config";
import ShareButtons from "@components/post/shareButtons.astro";
import ImageWrapper from "@components/common/imageWrapper.astro";

// ❯ PROPS
interface Props {
	title: string;
	id: string;
	pubDate: Date;
	class: string;
	author: string;
	sourceLink: string;
	licenseName: string;
	licenseUrl: string;
	postUrl?: string;
	cover?: string;
	coverBasePath?: string;
}

// ❯ PROPS DESTRUCTURING
const {
	title,
	id,
	pubDate,
	author,
	sourceLink,
	licenseName,
	licenseUrl,
	postUrl: propPostUrl,
	cover,
	coverBasePath = "/",
} = Astro.props;
const className = Astro.props.class;

// ❯ CONFIGURATION
const profileConf = profileConfig;
const licenseConf = postConfig.license;

// ❯ COMPUTED
const postUrl = sourceLink || propPostUrl || getPostUrlBySlug(id);

// @docs Build an absolute URL for social share targets. If postUrl is already
//       absolute (e.g. when sourceLink is provided), use it as-is.
const absolutePostUrl = postUrl.startsWith("http")
    ? postUrl
    : new URL(postUrl, siteConfig.siteURL).href;

// ❯ COVER BACKGROUND
// @docs When a cover is present the card becomes a dark social-card style:
//       layer 0 = cover image at low opacity, layer 1 = black overlay,
//       layer 2 = CC watermark, layer 3 = all text content.
//       Text colour tokens switch to white-based so the card reads well
//       in both light and dark mode without any mode-conditional logic.
const hasCover    = !!cover;
const titleClass  = hasCover
    ? "font-bold text-white/90"
    : "transition font-bold text-black/75 dark:text-white/75";
const labelClass  = hasCover
    ? "text-xs text-white/50"
    : "transition text-black/30 dark:text-white/30 text-sm";
const valueClass  = hasCover
    ? "text-white/85 line-clamp-2"
    : "transition text-black/75 dark:text-white/75 line-clamp-2";
const ccIconClass = hasCover
    ? "text-white/[0.06]"
    : "text-black/5 dark:text-white/5";
---

<!-- ❯ RENDER -->
<div class={`relative transition overflow-hidden bg-(--license-block-bg) py-5 px-6 ${className}`}>

    {/* ── Layer 0: cover image (rendered at low opacity) */}
    {hasCover && (
        <div class="absolute inset-0 opacity-30 pointer-events-none">
            <ImageWrapper
                src={cover!}
                basePath={coverBasePath}
                alt=""
                class="absolute inset-0"
                loading="eager"
            />
        </div>
    )}

    {/* ── Layer 1: dark overlay — ensures text is readable over any cover */}
    {hasCover && (
        <div class="absolute inset-0 bg-black/60 pointer-events-none" />
    )}

    {/* ── Layer 2: CC watermark — sits above the overlay, below content */}
    <Icon
        name="fa6-brands:creative-commons"
        class={`transition text-[15rem] absolute pointer-events-none right-6 top-1/2 -translate-y-1/2 ${ccIconClass}`}
    />

    {/* ── Layer 3: all card content */}
    <div class="relative z-10">
        <div class={titleClass}>
            {title}
        </div>
        <a href={postUrl} class="link text-(--primary)">
            {postUrl}
        </a>
        <div class="flex gap-6 mt-2">
            <div>
                <div class={labelClass}>{i18n(I18nKey.author)}</div>
                <div class={valueClass}>{author || profileConf.name}</div>
            </div>
            <div>
                <div class={labelClass}>{i18n(I18nKey.publishedAt)}</div>
                <div class={valueClass}>{formatDateToYYYYMMDD(pubDate)}</div>
            </div>
            <div>
                <div class={labelClass}>{i18n(I18nKey.license)}</div>
                <a
                    href={licenseName ? (licenseUrl || undefined) : licenseConf.url}
                    target="_blank"
                    class="link text-(--primary) line-clamp-2"
                >{licenseName || licenseConf.name}</a>
            </div>
        </div>

        <!-- ❯ @gogogo new page — ShareButtons below license meta -->
        <ShareButtons
            title={title}
            absoluteUrl={absolutePostUrl}
            cover={cover}
            coverBasePath={coverBasePath}
            hasDarkBg={hasCover}
        />
    </div>
</div>
