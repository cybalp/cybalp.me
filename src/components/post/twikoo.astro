---
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
// ❯ @status OK!
// ❯ @path ./src/components/post/twikoo.astro
// ❯ @desc Twikoo comment system component.
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

// ❯ IMPORTS
import { postConfig } from "@/config";

// ❯ PROPS
interface Props {
	path: string;
}

// ❯ CONFIGURATION
const config = {
	...postConfig.comment.twikoo,
	el: "#tcomment",
	path: Astro.props.path,
};
---

<!-- ❯ RENDER -->
<div id="tcomment"></div>

<!-- ❯ SCRIPTS -->
<script>
    import "@/plugins/twikoo-scroll-protection";
</script>
<script is:inline define:vars={{ config }}>
    // ❯ @doc Creates Twikoo configuration object.
    function createTwikooConfig() {
        return {
            ...config,
            el: '#tcomment'
        };
    }

    // ❯ @doc Loads Twikoo script dynamically.
    function loadTwikooScript() {
        return new Promise((resolve, reject) => {
            if (typeof twikoo !== 'undefined') {
                resolve();
                return;
            }
            const script = document.createElement('script');
            script.src = '/assets/js/twikoo.all.min.js';
            script.async = true;
            script.onload = resolve;
            script.onerror = reject;
            document.head.appendChild(script);
        });
    }

    // ❯ @doc Initializes Twikoo comment system.
    async function initTwikoo() {
        const commentEl = document.getElementById('tcomment');
        if (!commentEl) return;
        try {
            await loadTwikooScript();
            if (typeof twikoo !== 'undefined') {
                commentEl.innerHTML = '';
                const dynamicConfig = createTwikooConfig();
                console.log('[Twikoo] Initializing config:', dynamicConfig);
                await twikoo.init(dynamicConfig);
                console.log('[Twikoo] Initialization complete');
            }
        } catch (error) {
            console.error('[Twikoo] Load or initialization failed:', error);
        }
    }

    // ❯ @doc Sets up lazy loading using Intersection Observer.
    function setupLazyLoad() {
        const commentEl = document.getElementById('tcomment');
        if (!commentEl) return;

        const observer = new IntersectionObserver((entries) => {
            if (entries[0].isIntersecting) {
                initTwikoo();
                observer.disconnect();
            }
        }, { rootMargin: '200px' }); // ❯ start loading 200px before intersection

        observer.observe(commentEl);
    }

    // ❯ setup lazy load on page load or transition
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupLazyLoad);
    } else {
        setupLazyLoad();
    }

    // ❯ re-setup after Swup page transition
    if (window.swup && window.swup.hooks) {
        window.swup.hooks.on('content:replace', setupLazyLoad);
    } else {
        document.addEventListener('swup:enable', function() {
            if (window.swup && window.swup.hooks) {
                window.swup.hooks.on('content:replace', setupLazyLoad);
            }
        });
    }

    // ❯ custom event listener
    document.addEventListener('cybalp:page:loaded', setupLazyLoad);
</script>