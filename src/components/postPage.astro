---
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
// ❯ @status OK!
// ❯ @path ./src/components/postPage.astro
// ❯ @desc Post list page component.
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

// ❯ IMPORTS
import type { CollectionEntry } from "astro:content";
import PostCard from "@components/post/postCard.astro";

// ❯ PROPS
const { page } = Astro.props;

// ❯ ANIMATION
let delay = 0;
const interval = 30; // ❯ milliseconds
---

<!-- ❯ TEMPLATE -->
<div class="transition flex flex-col gap-4 py-1 md:py-0 md:gap-5 mb-4">
    {page.data.map((entry: CollectionEntry<"posts">) => (
        <PostCard
            entry={entry}
            class:list="onload-animation-up"
            style={`animation-delay: ${delay++ * interval}ms;`}
        ></PostCard>
    ))}
</div>