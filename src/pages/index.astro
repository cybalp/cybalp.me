---
// Maintenance
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CYBALP // OFFLINE</title>
</head>
<body>
    <div class="crt-overlay"></div>
    <div class="scanlines"></div>
    
    <div class="terminal-container">
        <header class="terminal-header">
            <span class="header-btn"></span>
            <span class="header-btn"></span>
            <span class="header-btn"></span>
            <div class="header-title">root@cybalp:~/system</div>
        </header>

        <div class="terminal-body">
            <h1 class="glitch-title" data-text="CYBALP">CYBALP</h1>
            
            <div class="status-box">
                <span class="prompt">></span>
                <span class="typing-text">Initializing security protocols...</span>
            </div>

            <div class="protocol-output">
                <p class="log">[OK] SystemOff</p>
                <p class="log">[RUNNING] MaintenanceMode</p>
                <p class="log warning">[WARN] ComingSoon</p>
                <p class="log status">STATUS: SystemLock: ACTIVE</p>
            </div>

            <div class="terminal-footer">
                <span class="cursor-line">_</span>
            </div>
        </div>

        <nav class="links">
            <a href="https://github.com/cybalp">[GITHUB]</a>
            <a href="https://instagram.com/cybalp">[INSTAGRAM]</a>
        </nav>
    </div>
</body>
</html>

<style is:global>
    @import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;800&display=swap');

    :root {
        --bg: #020202;
        --green: #00ff41;
        --dark-green: #003b00;
        --red: #ff003c;
        --glow: rgba(0, 255, 65, 0.4);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; cursor: none; }

    body {
        background-color: var(--bg);
        color: var(--green);
        font-family: 'JetBrains Mono', monospace;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        position: relative;
    }

    .crt-overlay {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: radial-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%),
                    linear-gradient(rgba(18, 16, 16, 0.1) 50%, rgba(0, 0, 0, 0.1) 50%);
        z-index: 100; pointer-events: none;
    }

    .scanlines {
        position: fixed; top: 0; left: 0; width: 100%; height: 100%;
        background: linear-gradient(to bottom, transparent 50%, rgba(0, 255, 65, 0.02) 50%);
        background-size: 100% 4px;
        z-index: 101; pointer-events: none;
        animation: scanline 10s linear infinite;
    }

    .terminal-container {
        width: 90%; max-width: 800px;
        background: rgba(0, 20, 0, 0.9);
        border: 1px solid var(--dark-green);
        box-shadow: 0 0 40px rgba(0, 255, 65, 0.1);
        z-index: 50;
    }

    .terminal-header {
        background: #111;
        padding: 10px;
        display: flex;
        align-items: center;
        gap: 8px;
        border-bottom: 1px solid #222;
    }

    .header-btn { width: 10px; height: 10px; border-radius: 50%; background: #ffffff; }
    .header-title { flex-grow: 1; text-align: center; font-size: 12px; color: #666; }

    .terminal-body { padding: 40px; }

    .glitch-title {
        font-size: clamp(3rem, 10vw, 6rem);
        font-weight: 800;
        margin-bottom: 20px;
        position: relative;
        animation: skew 3s infinite;
    }

    .glitch-title::before, .glitch-title::after {
        content: attr(data-text);
        position: absolute; top: 0; left: 0; width: 100%; opacity: 0.8;
    }
    .glitch-title::before { color: var(--red); z-index: -1; animation: glitch 0.3s cubic-bezier(.25,.46,.45,.94) both infinite; }
    .glitch-title::after { color: #0ff; z-index: -2; animation: glitch 0.3s cubic-bezier(.25,.46,.45,.94) reverse both infinite; }

    .status-box { margin-bottom: 30px; font-size: 1.2rem; display: flex; gap: 10px; }
    .prompt { font-weight: bold; }

    .protocol-output { font-size: 0.9rem; text-align: left; opacity: 0.8; }
    .log { margin: 8px 0; animation: typing 0.5s steps(30, end) forwards; overflow: hidden; white-space: nowrap; }
    .log.warning { color: var(--red); font-weight: bold; }
    .log.status { margin-top: 20px; color: #fff; border-top: 1px solid #222; padding-top: 10px; }

    .cursor-line { animation: blink 1s infinite; font-weight: bold; font-size: 1.5rem; }

    .links { display: flex; justify-content: center; gap: 20px; margin-top: 30px; border-top: 1px solid #111; padding-top: 20px; }
    .links a { color: #ffffff; text-decoration: none; font-size: 0.8rem; transition: 0.1s; }
    .links a:hover { color: #ffffff; text-shadow: 0 0 10px var(--green); }


    @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
    @keyframes scanline { from { transform: translateY(0); } to { transform: translateY(100vh); } }
    @keyframes skew { 0% { transform: skew(0deg); } 20% { transform: skew(2deg); } 40% { transform: skew(-2deg); } 100% { transform: skew(0deg); } }
    
    @keyframes glitch {
        0% { transform: translate(0) }
        20% { transform: translate(-3px, 3px) }
        40% { transform: translate(-3px, -3px) }
        60% { transform: translate(3px, 3px) }
        80% { transform: translate(3px, -3px) }
        100% { transform: translate(0) }
    }

    @keyframes typing { from { width: 0; } to { width: 100%; } }

    body::after {
        content: '';
        position: fixed;
        width: 20px; height: 20px;
        border: 1px solid var(--green);
        pointer-events: none;
        z-index: 1000;
        transform: translate(-50%, -50%);
        mix-blend-mode: difference;
    }
</style>

<script>

    const cursor = document.querySelector('body');
    window.addEventListener('mousemove', (e) => {
        cursor.style.setProperty('--x', e.clientX + 'px');
        cursor.style.setProperty('--y', e.clientY + 'px');
    });


    document.addEventListener('mousemove', e => {
        const x = e.clientX;
        const y = e.clientY;
        const style = document.createElement('style');
        style.innerHTML = `body::after { left: ${x}px; top: ${y}px; }`;
        document.head.appendChild(style);
        if(document.head.children.length > 20) {
            document.head.removeChild(document.head.children[10]);
        }
    });
</script>