---

import BackwardButton from "@components/backwardButton.astro";
import ImageWrapper from "@components/common/imageWrapper.astro";
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
// ❯ @status OK!
// ❯ @path ./src/pages/media.astro
// ❯ @desc Media listing page component.
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
// ❯ IMPORTS
import { LinkPresets } from "@constants/link-presets";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import GridLayout from "@layouts/grid.astro";
import { sortedAlbums } from "@utils/media";
import { LinkPreset } from "@/types/config";

// ❯ CONFIGURATION
const pageTitle = LinkPresets[LinkPreset.Media].name;
const pageDescription = LinkPresets[LinkPreset.Media].description;
const albumsData = sortedAlbums.filter((album) => album.visible);

// ❯ UTILITIES
// ❯ @doc Parses markdown link format into text and URL.
function parseMarkdownLink(link: string): { text: string; url: string } | null {
	const markdownLinkRegex = /\[([^\]]+)\]\(([^)]+)\)/;
	const match = link.match(markdownLinkRegex);
	if (match) {
		return { text: match[1], url: match[2] };
	}
	return null;
}
---

<GridLayout title={pageTitle} description={pageDescription}>
    <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            <BackwardButton currentPath={Astro.url.pathname} />
            <header class="mb-8">
                <h1 class="text-2xl md:text-3xl lg:text-4xl font-extrabold mb-3 arge-title">
                    {pageTitle}
                </h1>
                <p class="text-neutral-600 dark:text-neutral-400">
                    {pageDescription}
                </p>
            </header>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {albumsData.map(album => (
                    <article
                        class="album-card group bg-white dark:bg-neutral-900 rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-all duration-300 border border-neutral-200 dark:border-neutral-800"
                    >
                        <a href={`/media/${album.id}/`} class="block">
                            <div class="aspect-4/3 overflow-hidden bg-neutral-100 dark:bg-neutral-700">
                                <ImageWrapper
                                    src={album.cover}
                                    basePath={album.basePath}
                                    alt={album.title}
                                    class="w-full h-full object-cover group-hover:scale-105 transition duration-300"
                                />
                            </div>
                            <div class="p-4">
                                <h3 class="font-bold text-lg text-neutral-900 dark:text-neutral-100 mb-2 group-hover:text-(--primary) transition-colors">
                                    {album.title}
                                </h3>
                                {album.description && (
                                    <p class="text-neutral-600 dark:text-neutral-400 text-sm mb-3 line-clamp-2">
                                        {album.description}
                                    </p>
                                )}
                                <div class="flex items-center justify-between text-xs text-neutral-500 dark:text-neutral-500">
                                    <div class="flex items-center gap-4">
                                        <span>{album.photos.length} {album.photos.length > 1 ? i18n(I18nKey.mediaPhotosCount) : i18n(I18nKey.mediaPhotoCount)}</span>
                                        {album.location && (
                                            album.location.startsWith('http://') || album.location.startsWith('https://') ? (
                                                <a 
                                                    href={album.location} 
                                                    target="_blank" 
                                                    rel="noopener noreferrer"
                                                    class="flex items-center gap-1 hover:text-(--primary) transition-colors"
                                                >
                                                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                                        <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
                                                    </svg>
                                                    {album.location}
                                                </a>
                                            ) : (
                                                <span class="flex items-center gap-1">
                                                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                                        <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
                                                    </svg>
                                                    {album.location}
                                                </span>
                                            )
                                        )}
                                        {album.url && (() => {
                                            const parsedLink = parseMarkdownLink(album.url);
                                            const linkUrl = parsedLink ? parsedLink.url : album.url;
                                            const linkText = parsedLink ? parsedLink.text : album.url;
                                            return (
                                                <a 
                                                    href={linkUrl} 
                                                    target="_blank" 
                                                    rel="noopener noreferrer"
                                                    class="flex items-center gap-1 hover:text-(--primary) transition-colors"
                                                >
                                                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                                        <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z"></path>
                                                        <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z"></path>
                                                    </svg>
                                                    {linkText}
                                                </a>
                                            );
                                        })()}
                                    </div>
                                    <time>{new Date(album.date).toLocaleDateString('zh-CN')}</time>
                                </div>
                                {album.tags && album.tags.length > 0 && (
                                    <div class="flex flex-wrap gap-1 mt-3">
                                        {album.tags.slice(0, 3).map(tag => (
                                            <span class="btn-regular h-6 text-xs px-2 rounded-lg">
                                                {tag}
                                            </span>
                                        ))}
                                        {album.tags.length > 3 && (
                                            <span class="btn-regular h-6 text-xs px-2 rounded-lg">
                                                +{album.tags.length - 3}
                                            </span>
                                        )}
                                    </div>
                                )}
                            </div>
                        </a>
                    </article>
                ))}
            </div>
            {albumsData.length === 0 && (
                <div class="text-center py-12">
                    <div class="text-neutral-400 dark:text-neutral-600 mb-4">
                        <svg class="w-16 h-16 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                    </div>
                    <h3 class="text-lg font-medium text-neutral-900 dark:text-neutral-100 mb-2">
                        {i18n(I18nKey.mediaEmpty)}
                    </h3>
                    <p class="text-neutral-600 dark:text-neutral-400">
                        {i18n(I18nKey.mediaEmptyDesc)}
                    </p>
                </div>
            )}
        </div>
    </div>
</GridLayout>

<style>
    .album-card:hover {
        translate: 0 -2px;
    }
    @keyframes fadeInUp {
        from {
            opacity: 0;
            translate: 0 20px;
        }
        to {
            opacity: 1;
            translate: 0 0;
        }
    }
    .album-card {
        animation: fadeInUp 0.3s ease-out;
    }
</style>

<script>
    // Prevents nested link clicks from bubbling to parent link
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.album-card a[target="_blank"]').forEach(link => {
            link.addEventListener('click', (e) => {
                e.stopPropagation();
            });
        });
    });
</script>