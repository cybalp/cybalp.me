---
import BackwardButton from "@components/backwardButton.astro";
import ImageWrapper from "@components/common/imageWrapper.astro";
import I18nKey from "@i18n/i18nKey";
import { i18n } from "@i18n/translation";
import GridLayout from "@layouts/grid.astro";
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
// ❯ @status OK!
// ❯ @path ./src/pages/media/[id]/index.astro
// ❯ @desc Individual album detail page.
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
// ❯ IMPORTS
import type { AlbumGroup } from "@utils/media";
import { sortedAlbums } from "@utils/media";

// ❯ STATIC PATH GENERATION
// ❯ @doc Generates static paths for visible albums.
export const getStaticPaths = async () => {
	return sortedAlbums
		.filter((album) => album.visible)
		.map((album) => ({
			params: { id: album.id },
			props: { album },
		}));
};

// ❯ TYPES
interface Props {
	album: AlbumGroup;
}

// ❯ PROPS EXTRACTION
const { album } = Astro.props;

// ❯ VALIDATION
if (!album) {
	return Astro.redirect("/404");
}

// ❯ UTILITY FUNCTIONS
// ❯ @doc Parses markdown link format [text](url) into structured object.
function parseMarkdownLink(link: string): { text: string; url: string } | null {
	const markdownLinkRegex = /\[([^\]]+)\]\(([^)]+)\)/;
	const match = link.match(markdownLinkRegex);
	if (match) {
		return { text: match[1], url: match[2] };
	}
	return null;
}
---

<!-- ❯ PAGE LAYOUT -->
<GridLayout title={album.title} description={album.description || album.title}>
    <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full">
            <!-- ❯ NAVIGATION -->
            <BackwardButton href="/media/" text={i18n(I18nKey.mediaBackToList)} />
            
            <!-- ❯ HEADER SECTION -->
            <header class="mb-8">
                <h1 class="text-2xl md:text-3xl lg:text-4xl font-extrabold mb-3 arge-title">
                    {album.title}
                </h1>
                {album.description && (
                    <p class="text-neutral-600 dark:text-neutral-400 mb-4">
                        {album.description}
                    </p>
                )}
                
                <!-- ❯ METADATA -->
                <div class="flex flex-wrap items-center gap-4 text-sm text-neutral-500 dark:text-neutral-500">
                    <span>{album.photos.length} {album.photos.length > 1 ? i18n(I18nKey.mediaPhotosCount) : i18n(I18nKey.mediaPhotoCount)}</span>
                    <time>{new Date(album.date).toLocaleDateString('zh-CN')}</time>
                    {album.location && (
                        album.location.startsWith('http://') || album.location.startsWith('https://') ? (
                            <a 
                                href={album.location} 
                                target="_blank" 
                                rel="noopener noreferrer"
                                class="flex items-center gap-1 hover:text-(--primary) transition-colors"
                            >
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
                                </svg>
                                {album.location}
                            </a>
                        ) : (
                            <span class="flex items-center gap-1">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"></path>
                                </svg>
                                {album.location}
                            </span>
                        )
                    )}
                    {album.url && (() => {
                        const parsedLink = parseMarkdownLink(album.url);
                        const linkUrl = parsedLink ? parsedLink.url : album.url;
                        const linkText = parsedLink ? parsedLink.text : album.url;
                        return (
                            <a 
                                href={linkUrl} 
                                target="_blank" 
                                rel="noopener noreferrer"
                                class="flex items-center gap-1 hover:text-(--primary) transition-colors"
                            >
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                    <path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z"></path>
                                    <path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z"></path>
                                </svg>
                                {linkText}
                            </a>
                        );
                    })()}
                </div>
                
                <!-- ❯ ALIAS -->
                {album.tags && album.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mt-4">
                        {album.tags.map(tag => (
                            <span class="btn-regular h-8 text-sm px-3 rounded-lg">
                                {tag}
                            </span>
                        ))}
                    </div>
                )}
            </header>
            
            <!-- ❯ PHOTO GALLERY -->
            <!-- @gogogo new album layout -->
            <div
                class={`photo-gallery moment-images ${album.layout === 'masonry' ? 'masonry-layout' : 'grid-layout'}`}
                data-layout={album.layout || 'grid'}
                data-columns={album.columns || 3}
            >
                {album.photos.map((photo, index) => {
                    const isHidden = album.pageSize !== undefined && index >= album.pageSize;
                    return (
                        <figure
                            class={`photo-item group relative overflow-hidden rounded-lg${isHidden ? ' photo-initially-hidden' : ''}`}
                            data-downloadable={photo.downloadable === true ? "true" : "false"}
                        >
                            <ImageWrapper
                                src={photo.src}
                                basePath={album.basePath}
                                alt={photo.alt}
                                class="photo-image w-full h-full object-cover group-hover:scale-105 transition-transform duration-300 cursor-pointer"
                            />
                        </figure>
                    );
                })}
            </div>

            <!-- ❯ LOAD MORE BUTTON -->
            {album.pageSize && album.pageSize < album.photos.length && (
                <div class="flex justify-center mt-8" id="gallery-load-more-wrapper">
                    <button
                        id="gallery-load-more"
                        class="btn-regular h-10 px-6 rounded-lg flex items-center gap-2 text-sm font-medium"
                        data-batch-size={album.pageSize}
                        data-total={album.photos.length}
                        data-visible={album.pageSize}
                    >
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <polyline points="6 9 12 15 18 9"/>
                        </svg>
                        Show more
                        <span id="gallery-load-counter" class="opacity-50">
                            ({album.pageSize} / {album.photos.length})
                        </span>
                    </button>
                </div>
            )}
        </div>
    </div>

    <!-- ❯ LOAD MORE SCRIPT -->
    <script>
        // @docs Reveals photos in batches matching album.pageSize.
        //       Fancybox re-queries the selector on each click, so newly revealed photos
        //       are automatically included in the gallery group without rebinding.
        //       Script lives inside GridLayout (#swup-container) so Swup re-executes it
        //       on every navigation — no manual page:view hook needed.
        const btn = document.getElementById("gallery-load-more") as HTMLButtonElement | null;
        const wrapper = document.getElementById("gallery-load-more-wrapper");
        const counter = document.getElementById("gallery-load-counter");

        if (btn) {
            const batchSize = parseInt(btn.dataset.batchSize ?? "10");
            const total    = parseInt(btn.dataset.total    ?? "0");
            let visible    = parseInt(btn.dataset.visible  ?? "0");

            const old = (btn as any).__loadMoreHandler;
            if (old) btn.removeEventListener("click", old);

            const clickHandler = () => {
                const hidden = document.querySelectorAll<HTMLElement>(
                    ".photo-gallery .photo-initially-hidden"
                );
                const toReveal = Array.from(hidden).slice(0, batchSize);

                toReveal.forEach((el, i) => {
                    el.classList.remove("photo-initially-hidden");
                    // @docs Staggered entrance: each card starts 40ms after the previous.
                    el.style.animationDelay = `${i * 40}ms`;
                    el.classList.add("photo-item-revealing");
                    el.addEventListener(
                        "animationend",
                        () => {
                            el.classList.remove("photo-item-revealing");
                            el.style.animationDelay = "";
                        },
                        { once: true }
                    );
                });

                visible += toReveal.length;

                const remaining = document.querySelectorAll(
                    ".photo-gallery .photo-initially-hidden"
                ).length;

                if (remaining === 0) {
                    wrapper?.remove();
                } else if (counter) {
                    counter.textContent = `(${visible} / ${total})`;
                }
            };

            (btn as any).__loadMoreHandler = clickHandler;
            btn.addEventListener("click", clickHandler);
        }
    </script>

    <!-- ❯ STYLES -->
    <style>
    /* ❯ GRID LAYOUT */
    .grid-layout {
        display: grid;
        gap: 1rem;
    }

    .grid-layout[data-columns="2"] {
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    }

    .grid-layout[data-columns="3"] {
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    }

    .grid-layout[data-columns="4"] {
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    }

    /* ❯ MASONRY LAYOUT */
    .masonry-layout {
        columns: 2;
        column-gap: 1rem;
    }

    @media (min-width: 768px) {
        .masonry-layout {
            columns: 3;
        }
    }

    @media (min-width: 1280px) {
        .masonry-layout[data-columns="4"] {
            columns: 4;
        }
    }

    .masonry-layout .photo-item {
        break-inside: avoid;
        margin-bottom: 1rem;
    }

    .grid-layout .photo-container {
        aspect-ratio: 1;
    }

    /* ❯ PAGINATION */
    .photo-initially-hidden {
        display: none;
    }

    @keyframes photo-reveal {
        from { opacity: 0; transform: scale(0.94) translateY(10px); }
        to   { opacity: 1; transform: scale(1) translateY(0); }
    }

    .photo-item-revealing {
        animation: photo-reveal 0.35s ease forwards;
    }
</style>

</GridLayout>