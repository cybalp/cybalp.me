---
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
// ❯ @status OK!
// ❯ @path ./src/pages/vault.astro
// ❯ @desc Vault posts listing page with tree-structured history.
// ❯ ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

// ❯ IMPORTS
import BackwardButton from "@components/backwardButton.astro";
import VaultPanel from "@components/VaultPanel.svelte";
import { LinkPresets } from "@constants/link-presets";
import GridLayout from "@layouts/grid.astro";
import {
	getCategoryList,
	getSortedPostsList,
	getTagList,
} from "@utils/content";
import { LinkPreset } from "@/types/config";

// ❯ CONFIGURATION
const pageTitle = LinkPresets[LinkPreset.Vault].name;
const pageDescription = LinkPresets[LinkPreset.Vault].description;

	// @gogogo vault - data source for VaultPanel
	// ❯ DATA FETCHING
const [sortedPostsList, categoryList, tagList] = await Promise.all([
	getSortedPostsList(),
	getCategoryList(),
	getTagList(),
]);
---

<GridLayout title={pageTitle} description={pageDescription}>
    <div class="flex w-full rounded-(--radius-large) overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full ">
            <BackwardButton currentPath={Astro.url.pathname} />
            <VaultPanel
				title={pageTitle}
				description={pageDescription}
				sortedPosts={sortedPostsList}
				categoryList={categoryList}
				tagList={tagList}
				client:load
			/>
        </div>
    </div>
</GridLayout>